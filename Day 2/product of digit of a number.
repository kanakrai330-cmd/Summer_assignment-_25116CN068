#include<iostream>
using namespace std;
int main () {
    int N, digit, prod=1;
    cout << "N is number whose sum of digit you need" << endl;
    cout << "Enter N = ";
    cin >> N;
    while(N>0){
        digit = N%10;
        prod*=digit;
        N = N/10;
    }
    cout << "Product = " ;
    cout << prod;
return 0;
}
