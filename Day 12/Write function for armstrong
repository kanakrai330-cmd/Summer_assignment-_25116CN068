#include <iostream>
using namespace std;

bool isArmstrong(int n) {
    int original = n, sum = 0, remainder;

    while (n != 0) {
        remainder = n % 10;
        sum += remainder * remainder * remainder;
        n /= 10;
    }

    return sum == original;
}

int main() {
    int n;

    cout << "Enter a number: ";
    cin >> n;

    if (isArmstrong(n))
        cout << n << " is an Armstrong number" << endl;
    else
        cout << n << " is not an Armstrong number" << endl;

    return 0;
}
