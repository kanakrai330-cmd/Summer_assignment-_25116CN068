#include <iostream>
using namespace std;

int main() {
    int n, original, reversed = 0, remainder;

    cout << "ENTER A NUMBER: ";
    cin >> n;

    original = n;

    while (n != 0) {
        remainder = n % 10;
        reversed = reversed * 10 + remainder;
        n /= 10;
    }

    if (original == reversed)
        cout << original << " is a Palindrome" << endl;
    else
        cout << original << " is not a Palindrome" << endl;

    return 0;
}
