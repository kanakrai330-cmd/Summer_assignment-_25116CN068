#include <iostream>
using namespace std;

int main(){
int n;
int even = 0, odd = 0;
cout << " ENTER THE SIZE OF ARRAY : ";
cin >> n;

int arr[n];

cout << " ENTER THE ELEMENTS IN ARRAY : ";
for (int i=0 ; i<n ; i++ ){
    cin >> arr[i];
}

for (int i=0 ; i<n ; i++ ){
    if(arr[i] % 2 == 0){
        even++;
    }else{
        odd++;
    }
}  
cout << " THE EVEN AND ODD ELEMENTS ARE : " << even << " AND "  << odd << endl;

    return 0;
}
