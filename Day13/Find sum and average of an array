#include <iostream>
using namespace std;

int main(){
    int sum = 0;
int n;
cout << " ENTER THE SIZE OF ARRAY : ";
cin >> n;
float average;

int arr[n];

cout << " ENTER THE ELEMENTS IN ARRAY : ";
for (int i=0 ; i<n ; i++ ){
    cin >> arr[i];
}
for (int i=0 ; i<n ; i++ ){
    sum += arr[i];
}
cout << " THE SUM OF ELEMENTS IN THE ARRAYS ARE : " << sum << endl;
average = (float)sum/n;
cout << " THE AVERAGE OF ELEMENTS IN THE ARRAYS ARE : " << average << endl;

    return 0;
}
